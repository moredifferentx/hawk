# ╔══════════════════════════════════════════════════════════════╗
# ║          DISCORD MUSIC BOT — CONFIGURATION                  ║
# ║  Copy this file to .env and fill in your values             ║
# ║  Or run: npm run bootstrap (auto-generates + auto Mongo)     ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── REQUIRED ───────────────────────────────────────────────────
# Get these from https://discord.com/developers/applications

BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here

# ─── DATABASE (optional) ───────────────────────────────────────
# MongoDB connection string. If left empty, bot works without DB
# (settings won't persist across restarts)
# Install MongoDB: https://www.mongodb.com/try/download/community
# Or use free cloud: https://www.mongodb.com/atlas

MONGO_URI=mongodb://localhost:27017/discord-music-bot

# ─── LAVALINK PRIMARY NODE ────────────────────────────────────
# Set this to your VPS-hosted Lavalink if you have one.
# Bot will still keep a local fallback Lavalink if enabled below.

LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# Optional explicit tiered nodes as JSON array:
# LAVALINK_NODES=[{"name":"Primary","host":"lavalink.example.com","port":2333,"password":"secret","secure":false},{"name":"Backup","host":"10.0.0.5","port":2333,"password":"secret","secure":false}]
LAVALINK_NODES=

# Local Lavalink fallback (auto-managed)
LAVALINK_ENABLE_LOCAL_FALLBACK=true
LAVALINK_LOCAL_HOST=127.0.0.1
LAVALINK_LOCAL_PORT=2333
LAVALINK_LOCAL_PASSWORD=youshallnotpass
LAVALINK_LOCAL_SECURE=false
LAVALINK_MANAGE_LOCAL=true
LAVALINK_JAVA_OPTS=-Xms512M -Xmx1024M -XX:+UseG1GC -Dsun.zip.disableMemoryMapping=true

# ─── SPOTIFY (optional — enhances search) ─────────────────────
# Create an app at: https://developer.spotify.com/dashboard
# Enables: Spotify URL support, Spotify search fallback

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── APPLE MUSIC (optional) ──────────────────────────────────
# Get from Apple Developer Program (requires paid account)

APPLE_MUSIC_TOKEN=

# ─── DEEZER (optional) ───────────────────────────────────────
# Works without key for basic playback

DEEZER_DECRYPTION_KEY=

# ─── AI / OPENAI (optional — enables smart autoplay) ─────────
# Get from: https://platform.openai.com/api-keys
# Powers: AI song recommendations, smart autoplay, trending

AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ─── CHANNEL (auto-set by /setup command) ─────────────────────
# You don't need to set this — use /setup in Discord instead

REQUEST_CHANNEL_ID=

# ─── BOT SETTINGS ────────────────────────────────────────────
# Customize bot behavior

DEFAULT_VOLUME=80
MAX_QUEUE_SIZE=500
AUTO_DELETE_DELAY=1500
EMBED_UPDATE_INTERVAL=5000
