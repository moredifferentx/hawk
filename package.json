{
  "name": "discord-music-bot",
  "version": "1.0.0",
  "description": "Self-hosted Discord music bot with AI autoplay, Lavalink, and dedicated request channel",
  "main": "src/bot.js",
  "type": "module",
  "scripts": {
    "start": "node setup.js",
    "stop": "node -e \"const{execSync}=require('child_process');try{execSync('pkill -f \\\"node.*bot.js\\\"',{stdio:'pipe'})}catch{}try{execSync('pkill -f \\\"node.*setup.js\\\"',{stdio:'pipe'})}catch{}try{execSync('pkill -f \\\"java.*Lavalink\\\"',{stdio:'pipe'})}catch{}console.log('✓ All bot processes stopped')\"",
    "bootstrap": "node setup.js --auto --with-mongo",
    "bot": "node src/bot.js",
    "dev": "node --watch src/bot.js",
    "deploy": "node src/deploy-commands.js",
    "setup": "node setup.js"
  },
  "keywords": [
    "discord",
    "music",
    "bot",
    "lavalink",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "mongoose": "^8.18.1",
    "openai": "^6.25.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "shoukaku": "^4.3.0",
    "uuid": "^13.0.0"
  }
}
